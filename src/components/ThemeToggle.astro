<button
  id="theme-toggle"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-border text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
  type="button"
  aria-label="Toggle theme"
>
  <svg
    class="sun"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <svg
    class="moon hidden"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<script>
  (function () {
    const toggle = document.getElementById("theme-toggle");
    const root = document.documentElement;
    const sun = toggle?.querySelector(".sun");
    const moon = toggle?.querySelector(".moon");
    const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");

    function setTheme(theme: "light" | "dark") {
      root.classList.toggle("dark", theme === "dark");
      root.style.colorScheme = theme;
      updateIcons();
    }

    function updateIcons() {
      const isDark = root.classList.contains("dark");
      sun?.classList.toggle("hidden", isDark);
      moon?.classList.toggle("hidden", !isDark);
    }

    updateIcons();

    toggle?.addEventListener("click", () => {
      const isDark = root.classList.contains("dark");
      const theme = isDark ? "light" : "dark";

      localStorage.setItem("theme", theme);
      setTheme(theme);
    });

    systemTheme.addEventListener("change", (event) => {
      if (localStorage.getItem("theme")) return;

      setTheme(event.matches ? "dark" : "light");
    });
  })();
</script>
