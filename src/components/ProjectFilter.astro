---
export interface Project {
  slug: string;
  title: string;
  description: string;
  repo?: string;
  url?: string;
  stack: string[];
  featured: boolean;
  status: "active" | "stable" | "archived" | "draft";
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const stacks = Array.from(new Set(projects.flatMap((project) => project.stack))).sort();
const statuses = Array.from(new Set(projects.map((project) => project.status))).sort();
const VISIBLE_STACKS = 6;
---

<section class="space-y-5">
  <div
    class="flex flex-col gap-3 border-y border-border py-4 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex flex-wrap gap-2" id="stack-filters" role="group" aria-label="Filter by stack">
      <button class="filter-button selected" type="button" data-stack="all">all</button>
      {stacks.map((stack, index) => (
        <button
          class={`filter-button ${index >= VISIBLE_STACKS ? "filter-button-hidden" : ""}`}
          type="button"
          data-stack={stack}
          data-collapsible={index >= VISIBLE_STACKS ? "true" : undefined}
        >
          {stack}
        </button>
      ))}
      {stacks.length > VISIBLE_STACKS && (
        <button
          class="filter-button filter-button-more"
          type="button"
          data-action="toggle"
          aria-expanded="false"
        >
          +{stacks.length - VISIBLE_STACKS} more
        </button>
      )}
    </div>
    <label class="flex items-center gap-2 text-sm text-muted-foreground">
      status
      <select
        id="status-filter"
        class="h-9 rounded-md border border-border bg-background px-2 text-sm text-foreground"
      >
        <option value="all" selected>all</option>
        {statuses.map((status) => (
          <option value={status}>{status}</option>
        ))}
      </select>
    </label>
  </div>

  <div class="grid gap-3" id="project-list">
    {projects.map((project) => (
      <article
        class="rounded-md border border-border p-4"
        data-stack={project.stack.join(" ")}
        data-status={project.status}
      >
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="text-base font-semibold">{project.title}</h2>
              <span class="rounded border border-border px-2 py-0.5 text-xs text-muted-foreground">
                {project.status}
              </span>
            </div>
            <p class="mt-2 max-w-prose text-sm leading-6 text-muted-foreground">
              {project.description}
            </p>
          </div>
          <div class="flex shrink-0 gap-2">
            {project.repo && (
              <a
                class="icon-button"
                href={project.repo}
                aria-label={`${project.title} repository`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m18 16 4-4-4-4" />
                  <path d="m6 8-4 4 4 4" />
                  <path d="m14.5 4-5 16" />
                </svg>
              </a>
            )}
            {project.url && (
              <a
                class="icon-button"
                href={project.url}
                aria-label={`${project.title} website`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M15 3h6v6" />
                  <path d="M10 14 21 3" />
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                </svg>
              </a>
            )}
          </div>
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          {project.stack.map((stack) => (
            <span class="rounded bg-muted px-2 py-1 text-xs text-muted-foreground">{stack}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  (function () {
    const stackButtons = document.querySelectorAll<HTMLButtonElement>("#stack-filters [data-stack]");
    const statusSelect = document.getElementById("status-filter") as HTMLSelectElement;
    const projects = document.querySelectorAll<HTMLElement>("#project-list > article");
    const toggleButton = document.querySelector<HTMLButtonElement>("#stack-filters [data-action='toggle']");
    const collapsible = document.querySelectorAll<HTMLButtonElement>("#stack-filters [data-collapsible='true']");

    let selectedStack = "all";
    let selectedStatus = "all";
    let expanded = false;

    function filter() {
      projects.forEach((article) => {
        const stacks = article.dataset.stack?.split(" ") ?? [];
        const stackMatch = selectedStack === "all" || stacks.includes(selectedStack);
        const statusMatch = selectedStatus === "all" || article.dataset.status === selectedStatus;
        article.hidden = !(stackMatch && statusMatch);
      });

      stackButtons.forEach((button) => {
        button.classList.toggle("selected", button.dataset.stack === selectedStack);
      });
    }

    stackButtons.forEach((button) => {
      button.addEventListener("click", () => {
        selectedStack = button.dataset.stack ?? "all";
        filter();
      });
    });

    statusSelect.addEventListener("change", () => {
      selectedStatus = statusSelect.value;
      filter();
    });

    toggleButton?.addEventListener("click", () => {
      expanded = !expanded;
      toggleButton.setAttribute("aria-expanded", String(expanded));
      collapsible.forEach((button) => {
        button.classList.toggle("filter-button-hidden", !expanded);
      });
      toggleButton.textContent = expanded ? "less" : `+${collapsible.length} more`;
    });
  })();
</script>

<style>
  .filter-button {
    border: 1px solid hsl(var(--border));
    border-radius: 0.375rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.875rem;
    height: 2.25rem;
    padding: 0 0.75rem;
  }

  .filter-button:hover,
  .filter-button.selected {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }

  .icon-button {
    align-items: center;
    border: 1px solid hsl(var(--border));
    border-radius: 0.375rem;
    color: hsl(var(--muted-foreground));
    display: inline-flex;
    height: 2.25rem;
    justify-content: center;
    width: 2.25rem;
  }

  .icon-button:hover {
    background: hsl(var(--muted));
    color: hsl(var(--foreground));
  }

  .filter-button-hidden {
    display: none;
  }

  .filter-button-more {
    border-style: dashed;
  }
</style>
