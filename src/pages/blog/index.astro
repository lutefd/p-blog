---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/utils";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();
const VISIBLE_TAGS = 6;
---

<BaseLayout title="Writing" description="Essays and notes by Luis Dourado.">
  <section class="container py-12 sm:py-16">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold tracking-normal">Writing</h1>
      <p class="mt-3 max-w-prose text-sm leading-6 text-muted-foreground">
        Essays about backend systems, platform work, software delivery, and the little decisions that compound.
      </p>
    </header>

    <div class="space-y-5">
      <div class="flex flex-wrap gap-2 border-y border-border py-4" id="tag-filters" role="group" aria-label="Filter by tag">
        <button class="filter-button selected" type="button" data-tag="all">all</button>
        {tags.map((tag, index) => (
          <button
            class={`filter-button ${index >= VISIBLE_TAGS ? "filter-button-hidden" : ""}`}
            type="button"
            data-tag={tag}
            data-collapsible={index >= VISIBLE_TAGS ? "true" : undefined}
          >
            {tag}
          </button>
        ))}
        {tags.length > VISIBLE_TAGS && (
          <button class="filter-button filter-button-more" type="button" data-action="toggle" aria-expanded="false">
            +{tags.length - VISIBLE_TAGS} more
          </button>
        )}
      </div>

      <div class="grid gap-3" id="post-list">
        {
          posts.map((post) => (
            <a
              class="rounded-md border border-border p-4 no-underline transition-colors hover:bg-muted"
              href={`/blog/${post.slug}`}
              data-tags={post.data.tags.join(" ")}
            >
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <h2 class="font-medium">{post.data.title}</h2>
                <time class="text-sm text-muted-foreground" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
              </div>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{post.data.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded bg-muted px-2 py-1 text-xs text-muted-foreground">{tag}</span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    (function () {
      const buttons = document.querySelectorAll<HTMLButtonElement>("#tag-filters [data-tag]");
      const posts = document.querySelectorAll<HTMLElement>("#post-list > a");
      const toggleButton = document.querySelector<HTMLButtonElement>("#tag-filters [data-action='toggle']");
      const collapsible = document.querySelectorAll<HTMLButtonElement>("#tag-filters [data-collapsible='true']");
      let selected = "all";
      let expanded = false;

      function filter() {
        posts.forEach((post) => {
          const tags = post.dataset.tags?.split(" ") ?? [];
          const match = selected === "all" || tags.includes(selected);
          post.hidden = !match;
        });

        buttons.forEach((button) => {
          button.classList.toggle("selected", button.dataset.tag === selected);
        });
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          selected = button.dataset.tag ?? "all";
          filter();
        });
      });

      toggleButton?.addEventListener("click", () => {
        expanded = !expanded;
        toggleButton.setAttribute("aria-expanded", String(expanded));
        collapsible.forEach((button) => {
          button.classList.toggle("filter-button-hidden", !expanded);
        });
        toggleButton.textContent = expanded ? "less" : `+${collapsible.length} more`;
      });
    })();
  </script>

  <style>
    .filter-button {
      border: 1px solid hsl(var(--border));
      border-radius: 0.375rem;
      color: hsl(var(--muted-foreground));
      font-size: 0.875rem;
      height: 2.25rem;
      padding: 0 0.75rem;
    }

    .filter-button:hover,
    .filter-button.selected {
      background: hsl(var(--primary));
      color: hsl(var(--primary-foreground));
    }

    .filter-button-hidden {
      display: none;
    }

    .filter-button-more {
      border-style: dashed;
    }
  </style>
</BaseLayout>
