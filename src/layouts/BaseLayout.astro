---
import "@/styles/global.css";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { site } from "@/lib/site";

 type Props = {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
};

const {
  title = site.title,
  description = site.description,
  image = "/og-image.png",
  type = "website",
} = Astro.props;
const pageTitle = title === site.title ? title : `${title} - ${site.name}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url).href;
const ogImageUrl = new URL(image, site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />
    <title>{pageTitle}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        const storedTheme = localStorage.getItem("theme");
        const theme =
          storedTheme ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");

        document.documentElement.style.colorScheme = theme;

        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body>
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-border">
        <nav class="container flex h-14 items-center justify-between gap-4">
          <a href="/" class="text-sm font-semibold no-underline">{site.name}</a>
          <div class="flex items-center gap-4 text-sm text-muted-foreground">
            <a class="hover:text-foreground" href="/work">work</a>
            <a class="hover:text-foreground" href="/blog">writing</a>
            <a class="hover:text-foreground" href="/about">about</a>
            <ThemeToggle />
          </div>
        </nav>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="container py-10 text-sm text-muted-foreground">
        <div class="flex flex-col gap-2 border-t border-border pt-6 sm:flex-row sm:items-center sm:justify-between">
          <p>Building a bit too much at times.</p>
          <div class="flex gap-4">
            <a class="hover:text-foreground" href={site.links.github}>GitHub</a>
            <a class="hover:text-foreground" href={site.links.linkedin}>LinkedIn</a>
            <a class="hover:text-foreground" href={site.links.email}>Email</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
